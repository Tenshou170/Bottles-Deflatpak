# Maintainer: The Bottles Developers
# Contributor/Modifications: Tenshou Zmeyev <https://github.com/Tenshou170/Bottles-Deflatpak>

pkgname=bottles-deflatpak
_pkgname=Bottles-Deflatpak
pkgver=63.2
pkgrel=1
pkgdesc='Easily manage wine and proton prefix (Native Deflatpak version)'
arch=(any)
url="https://github.com/Tenshou170/Bottles-Deflatpak"
license=(GPL-3.0-only)
provides=(bottles)
conflicts=(bottles)
depends=(
  cabextract
  dconf
  gamemode
  gtk4
  gtksourceview5
  hicolor-icon-theme
  icoextract
  imagemagick
  libadwaita
  p7zip
  patool
  python
  python-chardet
  python-fvs
  python-gobject
  python-markdown
  python-orjson
  python-pathvalidate
  python-pycurl
  python-requests
  python-yaml
  webkit2gtk
  xorg-xdpyinfo
  vkbasalt-cli
  bubblewrap
  umu-launcher
  python-yara
  libportal-gtk4
)
optdepends=(
  gvfs
  lib32-gamemode
  lib32-gnutls
  lib32-vkd3d
  lib32-vulkan-icd-loader
  vkd3d
  vulkan-icd-loader
  wine
)
makedepends=(
  blueprint-compiler
  meson
  ninja
)
source=("bottles-v${pkgver}.tar.gz::${url}/archive/refs/tags/v${pkgver}.tar.gz")
sha256sums=('SKIP')

prepare() {
  :
}

build() {
  cd "${srcdir}/${_pkgname}-${pkgver}"
  meson setup --prefix='/usr' build
  ninja -C build
}

package() {
  cd "${srcdir}/${_pkgname}-${pkgver}"
  DESTDIR="${pkgdir}" ninja -C build install
}
