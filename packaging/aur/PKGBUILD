# Maintainer: The Bottles Developers
# Contributor/Modifications: Tenshou Zmeyev <https://github.com/Tenshou170/Bottles-Deflatpak>

pkgname=bottles-deflatpak
_pkgname=Bottles-Deflatpak
pkgver=64.1
pkgrel=1
pkgdesc='Easily manage Wine and Proton prefixes (native fork without Flatpak)'
arch=(any)
url="https://github.com/Tenshou170/Bottles-Deflatpak"
license=(GPL-3.0-only)
provides=(bottles)
conflicts=(bottles)
depends=(
  cabextract
  dconf
  gamemode
  gtk4
  gtksourceview5
  hicolor-icon-theme
  icoextract
  imagemagick
  libadwaita
  libportal-gtk4
  p7zip
  patool
  python
  python-chardet
  python-gobject
  python-markdown
  python-pathvalidate
  python-pefile
  python-pycurl
  python-requests
  python-yaml
  python-yara
  vkbasalt-cli
  bubblewrap
  fvs2
  umu-launcher
  xorg-xdpyinfo
)
optdepends=(
  'gvfs: GVFS integration'
  'lib32-gamemode: 32-bit GameMode support'
  'lib32-gnutls: 32-bit TLS support for Wine'
  'lib32-vkd3d: 32-bit VKD3D support'
  'lib32-vulkan-icd-loader: 32-bit Vulkan support'
  'vkd3d: VKD3D support'
  'vulkan-icd-loader: Vulkan support'
  'wine: Wine runner'
  'gamescope: Gamescope compositor'
  'mangohud: Performance overlay'
  'vmtouch: File preloading'
)
makedepends=(
  blueprint-compiler
  meson
  ninja
)
source=("bottles-v${pkgver}.tar.gz::${url}/archive/refs/tags/v${pkgver}.tar.gz")
sha256sums=('SKIP')

prepare() {
  :
}

build() {
  cd "${srcdir}/${_pkgname}-${pkgver}"
  meson setup --prefix='/usr' build
  ninja -C build
}

package() {
  cd "${srcdir}/${_pkgname}-${pkgver}"
  DESTDIR="${pkgdir}" ninja -C build install
}
